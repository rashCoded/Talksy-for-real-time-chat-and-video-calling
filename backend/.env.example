# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git

# Database
DB_URL=jdbc:mysql://localhost:3306/talksy_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# JWT
JWT_SECRET=your_long_random_jwt_secret_here_min_32_chars

# CORS
CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Email (Gmail SMTP - use an App Password, NOT your real Gmail password)
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
